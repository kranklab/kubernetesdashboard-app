{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "app",
  "name": "Kubernetes-Dashboard",
  "id": "kranklab-kubernetesdashboard-app",
  "backend": true,
  "executable": "gpx_kubernetes_dashboard",
  "info": {
    "keywords": ["app"],
    "description": "",
    "author": {
      "name": "Kranklab"
    },
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "screenshots": [],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "includes": [
    {
      "type": "page",
      "name": "Home",
      "path": "/a/%PLUGIN_ID%/home",
      "addToNav": true,
      "defaultNav": true
    },
    {
      "type": "page",
      "name": "Workloads",
      "path": "/a/%PLUGIN_ID%/fasg",
      "addToNav": true,
      "defaultNav": false
    },
    {
      "type": "page",
      "name": "Networking",
      "path": "/a/%PLUGIN_ID%/networking",
      "addToNav": true,
      "defaultNav": false
    },
    {
      "type": "page",
      "name": "Config & Storage",
      "path": "/a/%PLUGIN_ID%/config-storage",
      "addToNav": true,
      "defaultNav": false
    },
    {
      "type": "page",
      "name": "Cluster",
      "path": "/a/%PLUGIN_ID%/cluster",
      "addToNav": true,
      "defaultNav": false
    },
    {
      "type": "page",
      "name": "Custom Resource Definitions",
      "path": "/a/%PLUGIN_ID%/crds",
      "addToNav": true,
      "defaultNav": false
    },
    {
      "type": "page",
      "name": "Page with tabs",
      "path": "/a/%PLUGIN_ID%/page-with-tabs",
      "addToNav": true,
      "defaultNav": false
    },
    {
      "type": "page",
      "name": "Page with drilldown",
      "path": "/a/%PLUGIN_ID%/page-with-drilldown",
      "addToNav": true,
      "defaultNav": false
    },
    {
      "type": "page",
      "name": "Hello world",
      "path": "/a/%PLUGIN_ID%/hello-world",
      "addToNav": true,
      "defaultNav": false
    }
  ],
  "dependencies": {
    "grafanaDependency": ">=10.4.0",
    "plugins": []
  }
}
